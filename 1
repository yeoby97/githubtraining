graph TD
    %% ===== Entry Layer =====
    subgraph ENTRY["진입점 (Entry Points)"]
        CLI["cli<br/>CLI 명령어"]
        ROOT["(root)<br/>nanobot.py / __main__<br/>Python SDK"]
        API["api<br/>OpenAI 호환 HTTP API"]
    end

    %% ===== Channel Layer =====
    CH["channels<br/>플랫폼 연동<br/>(Telegram/Discord/Slack...)"]

    %% ===== Bus =====
    BUS["bus<br/>MessageBus (async 큐)<br/>Inbound/Outbound 이벤트"]

    %% ===== Agent Core =====
    subgraph CORE["에이전트 코어"]
        AGENT["agent<br/>loop · runner · memory<br/>context · hook · skills"]
        TOOLS["agent/tools<br/>fs · shell · web · mcp<br/>cron · spawn · self"]
    end

    %% ===== Supporting =====
    PROV["providers<br/>LLM 공급자<br/>(Anthropic/OpenAI/Azure...)"]
    SESS["session<br/>세션 히스토리·compaction<br/>goal_state"]
    CONF["config<br/>Pydantic 설정 스키마"]
    SEC["security<br/>워크스페이스/네트워크 정책"]
    UTIL["utils<br/>공용 헬퍼"]
    WEBUI["webui<br/>게이트웨이 라우트/API"]

    %% ===== Peripheral =====
    CMD["command<br/>슬래시 명령 라우터"]
    CRON["cron<br/>스케줄 서비스"]
    PAIR["pairing<br/>DM 승인 저장소"]
    APPS["apps<br/>CLI 앱 프로토콜"]

    %% ===== Edges: entry =====
    CLI --> CH & PROV & CONF & BUS & CRON & SESS & AGENT & API
    ROOT --> AGENT & CONF & PROV & CLI
    API --> UTIL & CONF

    %% ===== Edges: channels =====
    CH --> BUS
    CH --> CONF
    CH --> WEBUI
    CH --> SESS & PAIR & CMD & PROV & SEC & UTIL

    %% ===== Edges: agent =====
    AGENT --> TOOLS
    AGENT --> PROV
    AGENT --> SESS
    AGENT --> BUS
    AGENT --> CONF
    AGENT --> SEC & CMD & CRON & APPS & UTIL

    TOOLS --> CONF
    TOOLS --> SEC
    TOOLS --> BUS & CRON & SESS & APPS & PROV & UTIL
    TOOLS -.순환.-> AGENT

    %% ===== Edges: support =====
    SESS --> BUS & PROV & CONF & UTIL
    PROV --> CONF & UTIL
    CONF -.lazy.-> TOOLS & PROV & CRON & SEC
    WEBUI --> CONF & PROV & TOOLS & SESS & APPS & SEC & BUS
    PAIR --> CONF
    CMD --> BUS & SESS & PAIR

    %% styling
    classDef entry fill:#e1f0ff,stroke:#2b6cb0,color:#000
    classDef core fill:#fff0e1,stroke:#c05621,color:#000
    classDef infra fill:#f0e1ff,stroke:#6b46c1,color:#000
    class CLI,ROOT,API entry
    class AGENT,TOOLS core
    class BUS,PROV,SESS,CONF infra